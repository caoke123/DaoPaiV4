# ==============================
# DaoPai V3 Backend 环境配置示例
# ==============================

# 后端服务端口
PORT=3300

# 当前运行环境
NODE_ENV=production

# PostgreSQL 数据库连接地址
# 本地 Docker 示例：
# DATABASE_URL=postgresql://daopai:daopai_password@localhost:5432/daopai_v3
DATABASE_URL=postgresql://daopai:daopai_password@localhost:5432/daopai_v3

# 是否启用 PostgreSQL
USE_POSTGRES=true

# 真实提交总开关
# 注意：
# false = 试运行模式，不会真实提交
# true  = 允许真实生产提交
# 天南大正式使用前，必须人工确认后再改为 true
ENABLE_REAL_SUBMIT=false

# 运行模式
# V3 当前使用 PlaywrightRuntime 稳定窗口管理链路
RUNTIME_MODE=playwright

# 日志级别
LOG_LEVEL=info

# 本地运行地址
FRONTEND_URL=http://localhost:5175

# 是否允许跨域，本地部署时使用 localhost
CORS_ORIGIN=http://localhost:5175
