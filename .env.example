# DaoPai V3 环境变量示例
#
# 使用方法：
#   cp .env.example .env
#   然后填入本机真实值
#
# 注意：
#   - .env 已在 .gitignore 中，不会被提交
#   - 真实账号密码严禁写入 Git
#   - PowerShell 环境变量优先于 .env（同名变量以 PowerShell 为准）
#   - V3 端口与历史项目完全隔离

# ── Runtime 模式 ──
# 推荐测试模式：playwright（真实 Chrome）
# 回退模式：legacy_easybr（旧 EasyBR 路径，保留为备用）
WINDOW_RUNTIME_MODE=playwright

# ── 测试账号（仅本机使用，不要提交真实值）──
# 通过环境变量传递，严禁硬编码到代码或日志
BNSY_TEST_USERNAME=
BNSY_TEST_PASSWORD=

# ── PostgreSQL 连接（V3 独立实例，端口 5436）──
PG_HOST=127.0.0.1
PG_PORT=5436
PG_USER=daopai
PG_PASSWORD=daopai_secret
PG_DATABASE=daopai_v3
PG_POOL_MAX=20

# ── 服务端口（V3 固定，与 V2 隔离）──
# V3 后端 3300
PORT=3300
# V3 前端开发服务器 5176
FRONTEND_PORT=5176
# V3 前端请求 V3 后端（开发态由 vite proxy /api → 3300 转发）
VITE_API_BASE_URL=http://localhost:3300

# ── 运行环境 ──
# production 时使用 SQLite，development 时使用 JSON 文件
# NODE_ENV=development

# ── JWT 认证（Phase 3-B）──
# JWT 签名密钥，生产环境请使用强随机字符串
JWT_SECRET=change-me-to-a-random-secret-string
# 默认超级管理员（仅首次启动时自动创建，后续不重复创建）
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin123456
