# DaoPai V4 环境变量示例
#
# 使用方法：
#   cp .env.example .env
#   然后填入本机真实值
#
# 注意：
#   - .env 已在 .gitignore 中，不会被提交
#   - 真实账号密码严禁写入 Git
#   - V4 端口与 V3 完全隔离

# ── Runtime 模式 ──
WINDOW_RUNTIME_MODE=playwright

# ── 测试账号（仅本机使用，不要提交真实值）──
BNSY_TEST_USERNAME=
BNSY_TEST_PASSWORD=

# ── V4 PostgreSQL（独立端口 5437，独立数据库 daopai_v4）──
PG_HOST=127.0.0.1
PG_PORT=5437
PG_USER=daopai_v4
PG_PASSWORD=daopai_v4_secret
PG_DATABASE=daopai_v4
PG_POOL_MAX=20

# ── V4 服务端口（与 V3 完全隔离）──
# V4 后端 3400
PORT=3400
# V4 前端开发服务器 5177
FRONTEND_PORT=5177
# V4 前端请求 V4 后端（开发态由 vite proxy /api → 3400 转发）
VITE_API_BASE_URL=http://localhost:3400

# ── 运行环境 ──
# NODE_ENV=development

# ── JWT 认证（Phase 3-B）──
JWT_SECRET=daopai-v4-local-dev-secret-change-before-production
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin123456

# ── 认证保护开关（Phase 3-C）──
AUTH_REQUIRED=false
