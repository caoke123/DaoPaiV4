{
  "name": "bnsy-operator-next",
  "version": "1.0.0",
  "description": "DaoPai 网点操作中心自动化系统（下一代 - Playwright 原生 + 会员隔离）",
  "scripts": {
    "preflight:v4": "node scripts/preflight-v4-isolation-check.mjs",
    "build": "tsc && npm --prefix packages/agent run build",
    "dev": "npm run preflight:v4 && tsx watch backend/index.ts",
    "start": "npm run preflight:v4 && node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:no-cloud-engine": "node scripts/check-no-cloud-engine.js"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "better-sqlite3": "^9.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.0",
    "fs-extra": "^11.0.0",
    "jsonwebtoken": "^9.0.3",
    "papaparse": "^5.4.0",
    "pg": "^8.22.0",
    "playwright": "^1.40.0",
    "uuid": "^9.0.0",
    "ws": "^8.21.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/fs-extra": "^11.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.0.0",
    "@types/papaparse": "^5.3.0",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^9.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.6.1"
  }
}
